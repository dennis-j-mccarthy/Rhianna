# Copy to .env and fill in. Loaded by prisma.config.ts (dotenv) and Next.js.

# Database connection. Two supported formats:
#   1. Managed Prisma Postgres / Accelerate (HTTP):
#      DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=__KEY__"
#   2. Direct Postgres connection (managed direct connection, or local `npx prisma dev`):
#      DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"
# The client (src/lib/db.ts) auto-selects the driver based on the URL scheme.
DATABASE_URL="postgres://user:password@host:5432/dbname?sslmode=require"

# Password for the /admin login. Choose something strong.
ADMIN_PASSWORD="change-me"

# Secret used to sign the admin session cookie. Generate with: openssl rand -hex 32
SESSION_SECRET="__GENERATE_A_LONG_RANDOM_STRING__"

# Anthropic API key — powers the AI "write article" feature in the admin.
# Create one at https://console.anthropic.com/ (Settings → API Keys). Server-side only.
ANTHROPIC_API_KEY="sk-ant-..."
